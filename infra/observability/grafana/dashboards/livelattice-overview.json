{
  "title": "LiveLattice Service Overview",
  "schemaVersion": 42,
  "version": 2,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "sum(rate(http_requests_total[5m])) by (service)", "legendFormat": "{{service}}" },
        { "expr": "sum(rate(http_server_requests_seconds_count[5m])) by (service)", "legendFormat": "{{service}} spring" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (service)", "legendFormat": "{{service}}" },
        { "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) by (service)", "legendFormat": "{{service}} spring" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le, service)) * 1000", "legendFormat": "{{service}} p95" },
        { "expr": "sum(rate(http_request_duration_ms_sum[5m])) by (service) / clamp_min(sum(rate(http_request_duration_ms_count[5m])) by (service), 1)", "legendFormat": "{{service}} avg" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU and memory process indicators",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "sum(process_cpu_usage) by (service)", "legendFormat": "{{service}} cpu" },
        { "expr": "sum(jvm_memory_used_bytes) by (service) / 1024 / 1024", "legendFormat": "{{service}} jvm memory MiB" },
        { "expr": "sum(process_resident_memory_bytes) by (service) / 1024 / 1024", "legendFormat": "{{service}} rss MiB" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
