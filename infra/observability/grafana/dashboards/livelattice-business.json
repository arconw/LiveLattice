{
  "title": "LiveLattice Business",
  "schemaVersion": 42,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Workspace and canvas activity",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "active_workspaces", "legendFormat": "active workspaces" },
        { "expr": "active_canvases", "legendFormat": "active canvases" },
        { "expr": "canvas_ops_total", "legendFormat": "canvas ops" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Domain throughput",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "rate(search_queries_total[5m])", "legendFormat": "search" },
        { "expr": "rate(imports_total[5m])", "legendFormat": "imports" },
        { "expr": "rate(exports_total[5m])", "legendFormat": "exports" },
        { "expr": "rate(notifications_sent_total[5m])", "legendFormat": "notifications" },
        { "expr": "rate(audit_events_total[5m])", "legendFormat": "audit events" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    }
  ]
}
